rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== RODINNÝ ALLOWLIST =====
    // Přístup k datům mají POUZE tyto Google účty.
    // Nový člen rodiny = přidat e-mail na řádek níže a nasadit pravidla.
    function isFamily() {
      return request.auth != null
        && request.auth.token.email in [
          'jarek.fuki@gmail.com',
          'jarda.fnukal@gmail.com',
          'johankafnukalova@gmail.com',
          'misaelka@gmail.com'
        ];
    }

    function isOwner(userId) {
      return isFamily() && request.auth.uid == userId;
    }

    match /appConfig/{docId} {
      allow read: if isFamily();
      allow write: if false;
    }

    match /userSettings/{userId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId);
    }

    match /familyMembers/{memberId} {
      allow read, write: if isFamily();
    }

    match /schedules/{scheduleId} {
      allow read, write: if isFamily();
    }

    match /mealOrders/{docId} {
      allow read, write: if isFamily();
    }

    match /calendarEvents/{eventId} {
      allow read: if isFamily();
      allow create: if isFamily() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isFamily();
    }

    match /recipes/{recipeId} {
      allow read: if isFamily();
      allow create, update, delete: if isFamily();
    }

    match /namedayPreferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Rodinná nástěnka — všichni členové rodiny čtou i píšou
    match /stickyNotes/{noteId} {
      allow read, write: if isFamily();
    }

    match /familyMessages/{messageId} {
      allow read: if isFamily();
      allow create: if isFamily();
      allow update: if isFamily() && resource.data.recipients.hasAny([request.auth.uid]);
      allow delete: if isFamily();
    }

    // 🔧 TODO: Implementovat role-based access control pro Tuya zařízení
    // (admin / user / viewer) — do té doby mají všichni členové rodiny plný přístup
    match /devices/{deviceId} {
      allow read, write: if isFamily();
    }

    match /notifications/{notificationId} {
      allow read, write: if isFamily() && request.auth.uid == resource.data.userId;
    }

    // Rodinný tablet - allFamily kolekce
    match /allFamily/{document=**} {
      allow read, write: if isFamily();
    }

    // Handwriting Notes - ručně psané poznámky (jen vlastník)
    match /handwritingNotes/{noteId} {
      allow read: if isFamily() && resource.data.userId == request.auth.uid;
      allow create: if isFamily() && request.resource.data.userId == request.auth.uid;
      allow update: if isFamily() && resource.data.userId == request.auth.uid;
      allow delete: if isFamily() && resource.data.userId == request.auth.uid;
    }

    // App Settings
    match /appSettings/{document=**} {
      allow read, write: if isFamily();
    }

    // Vizualizace domu
    match /houses/{houseId} {
      allow read: if isFamily();
      allow create: if isFamily() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isFamily() && resource.data.userId == request.auth.uid;
    }

    // Patra domu (sdílená v rámci rodiny)
    match /floors/{floorId} {
      allow read: if isFamily();
      allow create, update, delete: if isFamily();
    }

    // Místnosti (jen vlastní)
    match /rooms/{roomId} {
      allow read: if isFamily() && resource.data.userId == request.auth.uid;
      allow create: if isFamily() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isFamily() && resource.data.userId == request.auth.uid;
    }

    // Doorbell events
    match /doorbell_events/{eventId} {
      allow read: if isFamily() &&
        (resource.data.userId == request.auth.uid ||
         exists(/databases/$(database)/documents/shared_rooms/$(request.auth.uid)));
      allow create, update: if isFamily() && request.resource.data.userId == request.auth.uid;
      allow delete: if isFamily() && resource.data.userId == request.auth.uid;
    }

    // Doorbell snapshots
    match /doorbell_snapshots/{snapshotId} {
      allow read: if isFamily() && resource.data.userId == request.auth.uid;
      allow create: if isFamily() && request.resource.data.userId == request.auth.uid;
      allow delete: if isFamily() && resource.data.userId == request.auth.uid;
    }

    // Price deals — čte appka (rodina), zapisuje jen Apify scraper přes Admin SDK
    // (Admin SDK pravidla obchází, takže write: false scraperu nevadí)
    match /priceDeals/{dealId} {
      allow read: if isFamily();
      allow write: if false;
    }

    // Aliasy produktů — spravuje appka (dřív bylo write: true pro KOHOKOLIV — opraveno)
    match /productAliases/{aliasId} {
      allow read, write: if isFamily();
    }
  }
}
