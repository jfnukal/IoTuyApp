rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /appConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /userSettings/{userId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId);
    }

    match /familyMembers/{memberId} {
      allow read, write: if request.auth != null;
    }

    match /schedules/{scheduleId} {
      allow read, write: if request.auth != null;
    }

    match /mealOrders/{docId} {
      allow read, write: if request.auth != null;
    }

match /calendarEvents/{eventId} {
  allow read: if request.auth != null;
  allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
  allow update, delete: if request.auth != null;
}

match /recipes/{recipeId} {
  allow read: if request.auth != null;
  allow create, update, delete: if request.auth != null;
}

    match /namedayPreferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rodinná nástěnka — všichni přihlášení čtou i píšou (sdílené, jako familyMessages)
    match /stickyNotes/{noteId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /familyMessages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.recipients.hasAny([request.auth.uid]);
      allow delete: if isSignedIn();
    }


      // 🔧 TODO: Implementovat role-based access control pro Tuya zařízení
      // Plán:
      // 1. Přidat do familyMembers pole "permissions" nebo "role"
      // 2. Role: 'admin' (plný přístup), 'user' (čtení + ovládání), 'viewer' (jen čtení)
      // 3. Citlivá zařízení (security, critical) jen pro 'admin'
      // 4. Funkce checkDevicePermission(userId, deviceId, action)
      //
      // Příklad budoucí struktury:
      // - familyMembers/{memberId} → { role: 'admin' | 'user' | 'viewer' }
      // - devices/{deviceId} → { userId, category, restrictedAccess: boolean }
      //
      // Dočasně: Všichni přihlášení mají plný přístup
      match /devices/{deviceId} {
        allow read, write: if request.auth != null;
      }

match /notifications/{notificationId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // 🆕 Pravidla pro rodinný tablet - allFamily kolekce
    match /allFamily/{document=**} {
      allow read, write: if request.auth != null;
    }

     // Handwriting Notes - Ručně psané poznámky
    match /handwritingNotes/{noteId} {
      // Čtení: pouze vlastník poznámky
      allow read: if request.auth != null &&
                     resource.data.userId == request.auth.uid;

      // Vytvoření: pouze přihlášený uživatel, a musí být vlastníkem
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;

      // Aktualizace: pouze vlastník poznámky
      allow update: if request.auth != null &&
                       resource.data.userId == request.auth.uid;

      // Smazání: pouze vlastník poznámky
      allow delete: if request.auth != null &&
                       resource.data.userId == request.auth.uid;
    }

     // App Settings - pouze čtení pro všechny, zápis jen pro autentizované
    match /appSettings/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ➕ NOVÉ: Pravidla pro vizualizaci domu - TOP-LEVEL kolekce
    match /houses/{houseId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
                         request.resource.data.userId == request.auth.uid;

      allow update, delete: if isSignedIn() &&
                                 resource.data.userId == request.auth.uid;
    }

    // 🏢 FLOORS - Patra domu (TOP-LEVEL kolekce)
    match /floors/{floorId} {
      // Čtení - všichni přihlášení (patra jsou sdílená v rámci domu)
      allow read: if isSignedIn();

      // Zápis - jen vlastník domu (kontrola přes houseId)
      allow create, update, delete: if isSignedIn();
    }

    // 🚪 ROOMS - Místnosti (TOP-LEVEL kolekce)
    match /rooms/{roomId} {
      // Čtení - pouze vlastní místnosti
      allow read: if isSignedIn() &&
                     resource.data.userId == request.auth.uid;

      // Vytvoření - jen pokud userId odpovídá auth
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid;

      // Update/Delete - jen vlastní místnosti
      allow update, delete: if isSignedIn() &&
                               resource.data.userId == request.auth.uid;
    }

     // === DOORBELL EVENTS (volitelné - pokud budeš ukládat historii zvonění) ===
    match /doorbell_events/{eventId} {
      // Čtení: pouze vlastník nebo sdílení uživatelé
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         exists(/databases/$(database)/documents/shared_rooms/$(request.auth.uid)));

      // Zápis: pouze vlastník
      allow create, update: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      // Smazání: pouze vlastník
      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // === DOORBELL SNAPSHOTS (volitelné - pro ukládání snímků) ===
    match /doorbell_snapshots/{snapshotId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;

      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

        // Price deals - čtení pro všechny, zápis jen pro admina
    match /priceDeals/{dealId} {
      allow read: if true;
      allow write: if false;
    }

    match /productAliases/{aliasId} {
      allow read: if true;
      allow write: if true;  // Později omezíme na přihlášené uživatele
    }
  }
}
